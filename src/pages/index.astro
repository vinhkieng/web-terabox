---
import Layout from '../components/Layout.astro';
---

<Layout title="TeraBox Technology | Cloud Service | Ho Chi Minh, Vietnam">
  
  <!-- Hero Section -->
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-content">
        <h1>Giải pháp Cloud đáng tin cậy cho doanh nghiệp Việt Nam</h1>
        <p>Chúng tôi cung cấp Private Cloud, Backup as a Service, DRaaS và Managed Service với tiêu chuẩn quốc tế</p>
        
        <div class="hero-buttons">
          <a href="/contact" class="btn-primary">Liên hệ tư vấn ngay</a>
          <a href="/services" class="btn-secondary">Xem dịch vụ của chúng tôi</a>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <div class="stats">
      <div class="stats-grid">
        <div class="stat-item">
          <h3>10+</h3>
          <p>Năm kinh nghiệm</p>
        </div>
        <div class="stat-item">
          <h3>300+</h3>
          <p>Dự án thành công</p>
        </div>
        <div class="stat-item">
          <h3>100+</h3>
          <p>Khách hàng doanh nghiệp</p>
        </div>
        <div class="stat-item">
          <h3>40+</h3>
          <p>Chuyên gia kỹ thuật</p>
        </div>
      </div>
    </div>

    <!-- Services Section -->
    <section class="services">
      <div class="section-title">
        <h2>Dịch vụ của chúng tôi</h2>
        <p>Chúng tôi mang đến các giải pháp Cloud toàn diện, an toàn và tối ưu chi phí cho doanh nghiệp</p>
      </div>

      <div class="services-grid">
        <div class="service-card">
          <img src="/private_cloud_services.jpg" alt="Private Cloud">
          <h3>Private Cloud</h3>
          <p>Hạ tầng Cloud riêng biệt, bảo mật cao, kiểm soát hoàn toàn dữ liệu cho doanh nghiệp lớn.</p>
        </div>
        <div class="service-card">
          <img src="/public_cloud_services.jpg" alt="Public Cloud">
          <h3>Public Cloud</h3>
          <p>Giải pháp Cloud công cộng linh hoạt, chi phí theo nhu cầu sử dụng.</p>
        </div>
        <div class="service-card">
          <img src="/backup_services.jpg" alt="Backup Services">
          <h3>Backup as a Service</h3>
          <p>Sao lưu dữ liệu tự động, an toàn, khôi phục nhanh chóng 24/7.</p>
        </div>
        <div class="service-card">
          <img src="/khien_services.jpg" alt="Backup Services">
          <h3>DRaaS</h3>
          <p>Disaster Recovery as a Service - Giải pháp phục hồi thảm họa nhanh chóng.</p>
        </div>
        <div class="service-card">
          <img src="/managed_Cloud_services.jpg" alt="Managed Cloud">
          <h3>Managed Cloud</h3>
          <p>Quản trị và vận hành Cloud chuyên nghiệp bởi đội ngũ chuyên gia.</p>
        </div>
        <div class="service-card">
          <img src="/clock_services.jpg" alt="Backup Services">
          <h3>Cloud Security</h3>
          <p>Bảo mật đa tầng, tuân thủ tiêu chuẩn ISO, SOC2 và quy định Việt Nam.</p>
        </div>
      </div>
    </section>

    <!-- Why Choose Us  -->
    <section class="why-choose">
      <div class="section-title">
        <h2>Tại sao nên chọn TeraBox Technology?</h2>
      </div>

      <div class="why-grid">
        
        <!-- Card 1 -->
        <div class="why-card">
          <h3>Chuyên sâu về Cloud Việt Nam</h3>
          <p class="short-desc">Hiểu rõ quy định pháp lý, hạ tầng trong nước và nhu cầu đặc thù của doanh nghiệp Việt.</p>
          <div class="expanded">
            <ul>
              <li>Tuân thủ Luật An ninh mạng và Luật Bảo vệ dữ liệu cá nhân</li>
              <li>Hạ tầng Data Center đạt chuẩn Tier 3 tại Việt Nam</li>
              <li>Hỗ trợ tiếng Việt 24/7 bởi đội ngũ địa phương</li>
            </ul>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="why-card">
          <h3>Bảo mật và Tuân thủ cao</h3>
          <p class="short-desc">Áp dụng tiêu chuẩn quốc tế và quy định bảo vệ dữ liệu của Việt Nam.</p>
          <div class="expanded">
            <ul>
              <li>Chứng nhận ISO 27001, SOC2 Type II</li>
              <li>Mã hóa dữ liệu đa tầng (AES-256)</li>
              <li>Giám sát bảo mật liên tục 24/7</li>
            </ul>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="why-card">
          <h3>Hiệu suất & Hỗ trợ 24/7</h3>
          <p class="short-desc">Đội ngũ chuyên gia luôn sẵn sàng hỗ trợ nhanh chóng.</p>
          <div class="expanded">
            <ul>
              <li>Thiết kế chịu lỗi, thời gian downtime tối thiểu</li>
              <li>Giám sát hệ thống thời gian thực</li>
              <li>Cam kết SLA uptime lên đến 99.99%</li>
            </ul>
          </div>
        </div>

        <!-- Card 4 - Mới -->
        <div class="why-card">
          <h3>Nền tảng ổn định, hiệu suất cao</h3>
          <p class="short-desc">Hạ tầng hiện đại giúp doanh nghiệp vận hành mượt mà và tin cậy.</p>
          <div class="expanded">
            <ul>
              <li>Sử dụng công nghệ từ các nhà cung cấp hàng đầu thế giới</li>
              <li>Tối ưu hiệu suất theo thời gian thực</li>
              <li>Hỗ trợ scale linh hoạt khi doanh nghiệp phát triển</li>
            </ul>
          </div>
        </div>

        <!-- Card 5 - Mới -->
        <div class="why-card">
          <h3>Kinh nghiệm trong dự án lớn</h3>
          <p class="short-desc">Đã triển khai thành công cho nhiều doanh nghiệp lớn tại Việt Nam.</p>
          <div class="expanded">
            <ul>
              <li>Thực hiện hơn 300 dự án Cloud cho doanh nghiệp vừa và lớn</li>
              <li>Am hiểu môi trường kinh doanh Việt Nam</li>
              <li>Giải pháp tùy chỉnh theo từng ngành nghề</li>
            </ul>
          </div>
        </div>

        <!-- Card 6 - Mới -->
        <div class="why-card">
          <h3>Chi phí tối ưu & Linh hoạt</h3>
          <p class="short-desc">Giải pháp phù hợp với ngân sách và nhu cầu thực tế của doanh nghiệp.</p>
          <div class="expanded">
            <ul>
              <li>Thanh toán theo mô hình Pay-as-you-go</li>
              <li>Tư vấn tối ưu chi phí định kỳ</li>
              <li>Không phát sinh chi phí ẩn</li>
            </ul>
          </div>
        </div>

      </div>
    </section>

    <!-- Clients / Khách hàng tiêu biểu - Kiểu card trắng -->
    <section class="clients">
      <div class="section-title">
        <h2>Một số khách hàng & đối tác tiêu biểu</h2>
        <p>Chúng tôi tự hào được đồng hành cùng nhiều doanh nghiệp hàng đầu tại Việt Nam</p>
      </div>

      <div class="client-logos">
        <div class="client-card">
          <img src="/criclek_customer.jpg" alt="Circle K">
        </div>
        <div class="client-card">
          <img src="/dbs_customer.jpg" alt="DBS">
        </div>
        <div class="client-card">
          <img src="/guardian_customer.jpg" alt="Guardian">
        </div>
        <div class="client-card">
          <img src="/jw marriot_customer.jpg" alt="Trung Nguyên Legend">
        </div>
        <div class="client-card">
          <img src="/mobiphone_customer.jpg" alt="PetroVietnam PVTrans">
        </div>
        <div class="client-card">
          <img src="/pvtrans_customer.jpg" alt="PetroVietnam PVTrans">
        </div>
        <div class="client-card">
          <img src="/trungnguyen_customer.jpg" alt="Trung Nguyên Legend">
        </div>
        <div class="client-card">
          <img src="/pizza_hut_customer.jpg" alt="Pizza Hut">
        </div>
      </div>
    </section>

  

</Layout>