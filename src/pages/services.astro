  // Gán data-section lên từng <a> dựa theo href hiện tại của chúng
  // (lần đầu load, href vẫn là #public-*)
  const sectionKeys = [
    'overview', 'service-overview', 'features', 'pricing',
    'why-us', 'platform', 'case-study', 'customers', 'faq'
  ];

  const subnavLinks = document.querySelectorAll<HTMLAnchorElement>('.subnav-link');

  subnavLinks.forEach((link, index) => {
    const key = sectionKeys[index];          // gán theo thứ tự trong danh sách
    if (key && map[key]) {
      link.href = '#' + map[key];            // cập nhật href đúng với service
      link.dataset.section = map[key];       // lưu lại để scroll spy dùng
    }
  });

  // ── 5. FAQ accordion ──────────────────────────────────────────────
  document.querySelectorAll('.faq-q').forEach(q => {
    q.addEventListener('click', () => {
      q.parentElement?.classList.toggle('open');
    });
  });

  // ── 6. Scroll spy: highlight subnav theo vị trí cuộn ─────────────
  window.addEventListener('scroll', () => {
    let current = '';

    subnavLinks.forEach(link => {
      const id = link.dataset.section;
      if (!id) return;
      const el = document.getElementById(id);
      if (el && window.scrollY >= el.offsetTop - 130) {
        current = id;
      }
    });

    subnavLinks.forEach(link => {
      link.classList.remove('active');
      if (link.dataset.section === current) {
        link.classList.add('active');
      }
    });
  });
</script>