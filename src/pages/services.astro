<Layout title="Dịch vụ Cloud | TeraBox Technology">

  <!-- Sub-nav anchor dịch vụ -->
  <nav class="service-subnav">
    <ul>
      <li><a href="#public-overview" class="subnav-link active">Tổng quan</a></li>
      <li><a href="#public-service-overview" class="subnav-link">Giới thiệu</a></li>
      <li><a href="#public-features" class="subnav-link">Tính năng</a></li>
      <li><a href="#public-pricing" class="subnav-link">Bảng giá</a></li>
      <li><a href="#public-why-us" class="subnav-link">Tại sao chọn chúng tôi</a></li>
      <li><a href="#public-platform" class="subnav-link">Nền tảng</a></li>
