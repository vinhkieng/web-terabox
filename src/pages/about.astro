          <div class="mosaic-lbl">Chuyên gia kỹ thuật giàu kinh nghiệm</div>
        </div>
        <div class="mosaic-card blue">
          <div class="mosaic-num">90%</div>
          <div class="mosaic-lbl">Tỷ lệ giữ chân khách hàng</div> 
